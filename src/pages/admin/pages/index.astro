---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import dbConnect from '../../../lib/db';
import { CustomPage } from '../../../lib/models';

await dbConnect();
const pages = await CustomPage.find().sort({ updatedAt: -1 });
---

<AdminLayout title="Pages Management" activeNav="pages">
  <div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
      <div>
        <h2>Website Pages</h2>
        <p style="color: var(--text-muted);">Manage your custom pages and drafts</p>
      </div>
      <a href="/admin/pages/new" class="btn btn-primary">+ Create New Page</a>
    </div>

    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Slug</th>
            <th>Status</th>
            <th>Last Updated</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {pages.map((page: any) => (
            <tr>
              <td>
                <div style="font-weight: 800; color: var(--primary);">{page.title}</div>
                {page.isHome && <span style="font-size: 0.7rem; background: #ecfdf5; color: #065f46; padding: 2px 8px; border-radius: 99px; border: 1px solid #10b981;">Home Page</span>}
              </td>
              <td><code>{page.slug === 'index' ? '/' : `/${page.slug}`}</code></td>
              <td>
                <span class={`status-badge ${page.status}`}>
                  {page.status.toUpperCase()}
                </span>
              </td>
              <td style="font-size: 0.85rem; color: var(--text-muted);">
                {new Date(page.updatedAt).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' })}
              </td>
              <td>
                <div style="display: flex; gap: 0.5rem;">
                  <a href={`/admin/pages/edit/${page._id}`} class="btn btn-sm" style="background: var(--primary-light); color: var(--primary);">Continue Editing</a>
                  <a href={page.slug === 'index' ? '/' : `/${page.slug}`} target="_blank" class="btn btn-sm" style="background: var(--bg-main); border: 1px solid var(--border);">View</a>
                  <button class="btn btn-sm btn-danger delete-page" data-id={page._id}>Delete</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <style is:global>
    .status-badge {
      padding: 4px 12px;
      border-radius: 99px;
      font-size: 0.75rem;
      font-weight: 700;
    }
    .status-badge.published { background: #ecfdf5; color: #065f46; }
    .status-badge.draft { background: #fff7ed; color: #9a3412; }
    
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; padding: 1rem; border-bottom: 2px solid var(--border); color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; }
    td { padding: 1rem; border-bottom: 1px solid var(--border); }
    tr:hover { background: #f8fafc; }
  </style>

  <script>
    document.querySelectorAll('.delete-page').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('Are you sure you want to delete this page? This action cannot be undone.')) return;
        const id = (btn as HTMLElement).dataset.id;
        const res = await fetch(`/api/pages/${id}`, { method: 'DELETE' });
        if (res.ok) window.location.reload();
      });
    });
  </script>
</AdminLayout>
