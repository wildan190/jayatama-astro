---
import dbConnect from '../lib/db';
import { CustomPage, WebConfig, Product } from '../lib/models';
import { SEO } from 'astro-seo';
import Header from '../components/Header.astro';

const { slug } = Astro.params;

await dbConnect();
let page;
if (!slug) {
  page = await CustomPage.findOne({ isHome: true });
  if (!page) page = await CustomPage.findOne({ slug: 'home' });
} else {
  page = await CustomPage.findOne({ slug: slug });
}
const config = await WebConfig.findOne();

// Fetch products for productList blocks if needed
const blockProducts: Record<string, any[]> = {};
for (const block of page?.blocks || []) {
  if (block.type === 'productList' && block.data.productIds?.length) {
    const products = await Product.find({ _id: { $in: block.data.productIds } });
    blockProducts[block._id.toString()] = products;
  }
}

if (!page) {
  return Astro.redirect('/404');
}

// Generate Schema Markup
const faqBlock = page.blocks.find((b: any) => b.type === 'faq');
const schemaMarkup = faqBlock ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqBlock.data.items.map((item: any) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
} : {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": page.title,
  "description": page.seo?.description
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEO
    title={page.seo?.title || page.title}
    description={page.seo?.description}
    canonical={Astro.url.href}
    extend={{
      meta: [
        { name: 'keywords', content: page.seo?.keywords?.join(', ') || '' }
      ]
    }}
    openGraph={{
      basic: {
        title: page.seo?.title || page.title,
        type: "website",
        image: page.seo?.ogImage || config?.logo || "",
      }
    }}
  />
  <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <style is:global>
    :root {
      --primary: #6366f1;
      --text: #0f172a;
      --bg: #ffffff;
    }
    body { font-family: 'Outfit', sans-serif; margin: 0; color: var(--text); }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
    img { max-width: 100%; height: auto; }
    
    /* Hero Block */
    .hero { 
      position: relative; 
      min-height: 80vh; 
      display: flex; 
      align-items: center; 
      color: white; 
      background-size: cover; 
      background-position: center;
    }
    .hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.5); }
    .hero-content { position: relative; z-index: 10; max-width: 800px; }
    
    /* Split Block */
    .split-section { padding: 5rem 0; }
    .split-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
    @media (max-width: 768px) { .split-grid { grid-template-columns: 1fr; gap: 2rem; } }
    
    /* CTA Block */
    .cta-banner { padding: 5rem 0; background: var(--primary); color: white; text-align: center; }
    .btn-white { background: white; color: var(--primary); padding: 1rem 2rem; border-radius: 12px; text-decoration: none; font-weight: 800; display: inline-block; margin-top: 2rem; }
    
    /* FAQ Block */
    .faq-section { padding: 5rem 0; background: #f8fafc; }
    .faq-item { background: white; padding: 1.5rem; border-radius: 16px; margin-bottom: 1rem; border: 1px solid #e2e8f0; }
    .faq-q { font-weight: 800; font-size: 1.1rem; margin-bottom: 0.5rem; color: var(--primary); }
    
    /* Rich Text Block */
    .rich-text { padding: 5rem 0; line-height: 1.8; }
    .rich-text h1, .rich-text h2 { color: var(--primary); margin-top: 2rem; }

    /* Product List Block */
    .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem; padding: 5rem 0; }
    .product-card { background: white; border-radius: 20px; overflow: hidden; border: 1px solid #f1f5f9; transition: 0.3s; text-decoration: none; color: inherit; position: relative; }
    .product-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
    .product-img { width: 100%; aspect-ratio: 1; object-fit: cover; }
    .product-info { padding: 1.5rem; }
    .product-name { font-weight: 800; font-size: 1.25rem; margin-bottom: 0.5rem; }
    .price-area { display: flex; align-items: center; gap: 0.75rem; }
    .price-discounted { color: #6366f1; font-weight: 800; font-size: 1.25rem; }
    .price-original { color: #94a3b8; text-decoration: line-through; font-size: 0.9rem; }
    .discount-badge { position: absolute; top: 1rem; right: 1rem; background: #ef4444; color: white; padding: 0.4rem 0.8rem; border-radius: 99px; font-weight: 800; font-size: 0.75rem; z-index: 10; }

    /* Clients Block */
    .clients-grid { display: flex; flex-wrap: wrap; gap: 3rem; justify-content: center; align-items: center; padding: 5rem 0; }
    .client-logo { height: 50px; width: auto; opacity: 0.5; filter: grayscale(100%); transition: 0.4s; }
    .client-logo:hover { opacity: 1; filter: grayscale(0%); transform: scale(1.1); }
  </style>
</head>
<body>
  <Header />
  
  {page.blocks.map((block: any) => {
    if (block.type === 'hero') return (
      <section class="hero" style={`background-image: url(${block.data.bgImage})`}>
        <div class="hero-overlay"></div>
        <div class="container">
          <div class="hero-content">
            <h1 style="font-size: 4rem; font-weight: 900; margin-bottom: 1.5rem; line-height: 1;">{block.data.title}</h1>
            <p style="font-size: 1.25rem; opacity: 0.9; margin-bottom: 2.5rem;">{block.data.subtitle}</p>
            {block.data.btnLabel && (
              <a href={block.data.btnUrl} class="btn-white">{block.data.btnLabel}</a>
            )}
          </div>
        </div>
      </section>
    );

    if (block.type === 'richText') return (
      <section class="rich-text">
        <div class="container" set:html={block.data.html}></div>
      </section>
    );

    if (block.type === 'split') return (
      <section class="split-section">
        <div class="container">
          <div class="split-grid" style={block.data.layout === 'right' ? 'direction: rtl' : ''}>
            <div style="direction: ltr">
              <img src={block.data.image} alt={block.data.title} style="border-radius: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.1);" />
            </div>
            <div style="direction: ltr">
              <h2 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 1.5rem;">{block.data.title}</h2>
              <div style="font-size: 1.1rem; color: #64748b;" set:html={block.data.text}></div>
            </div>
          </div>
        </div>
      </section>
    );

    if (block.type === 'faq') return (
      <section class="faq-section">
        <div class="container">
          <h2 style="text-align: center; margin-bottom: 3rem; font-size: 2.5rem; font-weight: 800;">Frequently Asked Questions</h2>
          <div style="max-width: 800px; margin: 0 auto;">
            {block.data.items.map((item: any) => (
              <div class="faq-item">
                <div class="faq-q">{item.q}</div>
                <div class="faq-a">{item.a}</div>
              </div>
            ))}
          </div>
        </div>
      </section>
    );

    if (block.type === 'cta') return (
      <section class="cta-banner">
        <div class="container">
          <h2 style="font-size: 3rem; font-weight: 900; margin-bottom: 1rem;">{block.data.title}</h2>
          <a href={block.data.btnUrl} class="btn-white" style="background: white; color: var(--primary);">{block.data.btnLabel}</a>
        </div>
      </section>
    );

    if (block.type === 'productList') return (
      <section class="container">
        <div class="product-grid">
          {blockProducts[block._id.toString()]?.map((p: any) => {
            const hasDiscount = p.discountPercentage > 0;
            const discountedPrice = hasDiscount ? p.price * (1 - p.discountPercentage / 100) : p.price;
            return (
              <a href={`/products/${p._id}`} class="product-card">
                {hasDiscount && <div class="discount-badge">{p.discountPercentage}% OFF</div>}
                <img src={p.image || 'https://placehold.co/400x400'} alt={p.name} class="product-img" />
                <div class="product-info">
                  <h3 class="product-name">{p.name}</h3>
                  <div class="price-area">
                    <span class="price-discounted">Rp {discountedPrice.toLocaleString('id-ID')}</span>
                    {hasDiscount && <span class="price-original">Rp {p.price.toLocaleString('id-ID')}</span>}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    );

    if (block.type === 'clients') return (
      <section class="container">
        <div class="clients-grid">
          {block.data.items?.map((item: any) => (
            <img src={item.image} alt="Client Logo" class="client-logo" />
          ))}
        </div>
      </section>
    );

    if (block.type === 'contactForm') return (
      <section class="container" style="padding: 5rem 0;">
        <div style="max-width: 600px; margin: 0 auto; padding: 3rem; background: #f8fafc; border-radius: 32px; border: 1px solid #e2e8f0; text-align: center;">
          <h2 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem;">{block.data.title}</h2>
          <p style="color: #64748b; margin-bottom: 2.5rem;">{block.data.subtitle}</p>
          
          <form class="whatsapp-form" data-phone={config?.whatsapp}>
            <div style="text-align: left; margin-bottom: 1.5rem;">
              <label style="display: block; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.9rem;">Your Name</label>
              <input type="text" name="name" placeholder="John Doe" required style="width: 100%; padding: 1rem; border: 1px solid #e2e8f0; border-radius: 12px; font-family: inherit;" />
            </div>
            <div style="text-align: left; margin-bottom: 2rem;">
              <label style="display: block; font-weight: 700; margin-bottom: 0.5rem; font-size: 0.9rem;">Message</label>
              <textarea name="message" placeholder="How can we help you?" required style="width: 100%; padding: 1rem; border: 1px solid #e2e8f0; border-radius: 12px; font-family: inherit; height: 120px;"></textarea>
            </div>
            <button type="submit" style="width: 100%; padding: 1.25rem; background: #25d366; color: white; border: none; border-radius: 16px; font-weight: 800; font-size: 1.1rem; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 0.75rem;">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              {block.data.btnLabel}
            </button>
          </form>
        </div>
      </section>
    );
  })}
  
  <script is:inline>
    document.querySelectorAll('.whatsapp-form').forEach(form => {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = form.querySelector('[name="name"]').value;
        const message = form.querySelector('[name="message"]').value;
        const phone = form.dataset.phone || '628123456789';
        
        const text = `Halo Jayatama, saya *${name}*.\n\n${message}`;
        const encodedText = encodeURIComponent(text);
        const url = `https://wa.me/${phone.replace(/[^0-9]/g, '')}?text=${encodedText}`;
        
        window.open(url, '_blank');
      });
    });
  </script>

  <footer style="padding: 5rem 0; background: #0f172a; color: white; text-align: center;">
    <div class="container">
      {config?.logo && <img src={config.logo} alt="Logo" style="height: 40px; margin-bottom: 2rem;" />}
      <p>&copy; {new Date().getFullYear()} {config?.webName}. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
